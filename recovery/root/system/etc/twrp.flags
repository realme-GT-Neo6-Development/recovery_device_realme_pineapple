# mount point   fstype  device                                    flags
# Logical partitions
/system_image   emmc    /dev/block/by-name/system                 flags=display="system Image";backup;flashimg
/odm_image      emmc    /dev/block/by-name/odm                    flags=display="odm Image";backup;flashimg
/odm            auto    odm                                       flags=display="odm"
/product        auto    product                                   flags=display="product"
/system_ext     auto    system_ext                                flags=display="system_ext"
/vendor_dlkm    auto    vendor_dlkm                               flags=display="vendor_dlkm"

# Metadata/Cache Properties
/metadata       f2fs    /dev/block/by-name/metadata               flags=display="Metadata";backup=1;wrappedkey
/cache          auto    /dev/block/by-name/oplusreserve2          flags=display="Cache";backup=1;wipeingui;wipeduringfactoryreset

# Other partitions
/boot           emmc    /dev/block/by-name/boot                   flags=slotselect
/init_boot      emmc    /dev/block/by-name/init_boot              flags=display="init_boot";backup;slotselect;flashimg=1
/recovery       emmc    /dev/block/by-name/recovery               flags=slotselect;display="recovery";backup;flashimg
/vendor_boot    emmc    /dev/block/by-name/vendor_boot            flags=slotselect;display="vendor_boot";backup;flashimg
/frp            emmc    /dev/block/by-name/frp                    flags=display="frp";wipeingui

# AVB partitions
/dtbo           emmc    /dev/block/by-name/dtbo                   flags=slotselect;display="dtbo";backup;flashimg
/vbmeta         emmc    /dev/block/by-name/vbmeta                 flags=slotselect;display="vbmeta";backup;flashimg
/vbmeta_system  emmc    /dev/block/by-name/vbmeta_system          flags=slotselect;display="vbmeta_system";backup;flashimg
/vbmeta_vendor  emmc    /dev/block/by-name/vbmeta_vendor          flags=slotselect;display="vbmeta_vendor";backup;flashimg

# Persistent Firmware & Properties
/firmware       vfat    /dev/block/by-name/modem                  flags=slotselect;display="Firmware";mounttodecrypt;fsflags="ro,shortname=lower,uid=1000,gid=1000,dmask=227,fmask=337,context=u:object_r:firmware_file:s0"
/persist        ext4    /dev/block/by-name/persist                flags=display="persist";
/persist_image  emmc    /dev/block/by-name/persist                flags=display="persist";backup;flashimg

# Modem partitions
/modem          emmc    /dev/block/by-name/modem                  flags=slotselect;backup;display="Modem"
/bluetooth      emmc    /dev/block/by-name/bluetooth              flags=slotselect;backup;display="Bluetooth"
/dsp            emmc    /dev/block/by-name/dsp                    flags=slotselect;backup;display="DSP"

# EFS partitions
/efs1           emmc    /dev/block/by-name/modemst1               flags=backup;display="EFS"
/efs2           emmc    /dev/block/by-name/modemst2               flags=backup;subpartitionof=/efs1
/efsc           emmc    /dev/block/by-name/fsc                    flags=backup;subpartitionof=/efs1
/efsg           emmc    /dev/block/by-name/fsg                    flags=backup;subpartitionof=/efs1

# Critical partitions
/static_nv_bk   emmc    /dev/block/by-name/oplusstanvbk           flags=slotselect;backup;display="oplusstanvbk"
/oplusdycnvbk   emmc    /dev/block/by-name/oplusdycnvbk           flags=slotselect;backup;display="oplusdycnvbk"

# Removable storage
/usb_otg        auto    /dev/block/sdg1 /dev/block/sdh1           flags=storage;wipeingui;removable;fsflags="utf8"
